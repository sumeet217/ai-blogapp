venv/
.venv/
env/
ENV/

# ─────────────────────────────────────────────────────────────
# Node / frontend generated files
# Frontend source is required because Docker builds React inside the image.
# ─────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.vite-temp/
frontend/.env
frontend/.env.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─────────────────────────────────────────────────────────────
# Django runtime files
# ─────────────────────────────────────────────────────────────
db.sqlite3
db.sqlite3-journal
*.sqlite3
staticfiles/
media/
*.log

# ─────────────────────────────────────────────────────────────
# OS files
# ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini


# IDE / Editor

.vscode/
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────
# Docker meta files (not needed inside the image)
# ─────────────────────────────────────────────────────────────
Dockerfile
docker-compose*.yaml
docker-compose*.yml
.dockerignore
nginx/

